# OpenWA gateway config for Tredev Gems — SAFE TO COMMIT (placeholders only).
# Copy to services/openwa.env and fill in. That file is gitignored (.env* rule).
#
#   cp services/openwa.env.example services/openwa.env

# ── Runtime ──────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=2785
API_PORT=2785
LOG_LEVEL=info
# Sessions are started explicitly from the Tredev admin panel, never on boot.
AUTO_START_SESSIONS=false
MAX_CONCURRENT_SESSIONS=1

# ── Engine ───────────────────────────────────────────────────────────────────
# baileys = WebSocket client, NO Chromium. Chosen so this fits a small Render
# instance; whatsapp-web.js would need ~2GB for its per-session Chromium.
ENGINE_TYPE=baileys
# Pulling the full history archive on connect is large and slow. Off.
BAILEYS_SYNC_FULL_HISTORY=false

# ── Datastore ────────────────────────────────────────────────────────────────
# SQLite keeps the gateway self-contained. Tredev mirrors every message into
# Supabase anyway (wa_chats / wa_messages), so this DB is not the system of record.
DATABASE_TYPE=sqlite
POSTGRES_BUILTIN=false
REDIS_ENABLED=false
REDIS_BUILTIN=false
MINIO_BUILTIN=false

# ── Storage / session state ──────────────────────────────────────────────────
# Both live under /app/data, which is the mounted volume (persistent disk on Render).
SESSION_DATA_PATH=/app/data/sessions
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=/app/data/media

# ── Access ───────────────────────────────────────────────────────────────────
# Only the Tredev backend calls this API. The dashboard origin is listed so the
# bundled UI works during local pairing.
CORS_ORIGINS=http://localhost:3000,http://localhost:2785

# ── Webhook delivery (inbound messages -> Tredev) ────────────────────────────
WEBHOOK_TIMEOUT=10000
WEBHOOK_RETRY_DELAY=5000
# NOTE: OpenWA blocks webhook delivery to loopback/private/link-local addresses by
# default (SSRF guard). Local dev and Render private networking are BOTH private
# addresses, so this must be relaxed for inbound messages to arrive. The exact flag
# is set in services/openwa.env once confirmed against the running build.
